# ── 비밀 정보 (절대 커밋 금지) ──
config.json
.env
*.key

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── OS / 에디터 ──
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── 문서 빌드 산출물(재생성 가능, 원본 md·이미지·docx는 추적) ──
docs/기획서_v2.html
docs/*.tmp

# ── 임시 ──
scratchpad/
*.log
